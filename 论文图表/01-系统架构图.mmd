graph TB
    subgraph 前端层["前端层 Presentation Layer"]
        VUE["Vue 3 SPA<br/>Vite + Element Plus<br/>ECharts + Pinia"]
        VANILLA["Vanilla JS SPA 静态页面<br/>原生 JavaScript<br/>ECharts + Fetch API"]
    end

    subgraph 网关层["网关层 Gateway"]
        UVICORN["Uvicorn ASGI Server<br/>静态文件服务 + API 路由"]
    end

    subgraph 后端层["后端层 Business Logic Layer"]
        ROUTER["路由层 Routers<br/>auth | videos | comments | dashboard | favorites"]
        AUTH["认证模块 Authentication<br/>JWT HS256 + bcrypt"]
        MIDDLEWARE["中间件 Middleware<br/>CORS | Bearer Token | 异常处理"]
        SCHEMA["数据校验 Pydantic Schemas<br/>Request / Response Validation"]
    end

    subgraph 数据层["数据层 Data Layer"]
        ORM["SQLAlchemy ORM<br/>声明式映射 | 会话管理"]
        DB[("数据库<br/>SQLite / MySQL")]
        CRAWLER["Scrapy 爬虫引擎<br/>B站API采集 | Pipeline入库"]
    end

    VUE --> UVICORN
    VANILLA --> UVICORN
    UVICORN --> ROUTER
    ROUTER --> AUTH
    ROUTER --> MIDDLEWARE
    MIDDLEWARE --> SCHEMA
    ROUTER --> ORM
    ORM --> DB
    CRAWLER --> DB
