flowchart TD
    subgraph 数据采集层["数据采集层 Data Collection"]
        API["B站热门视频 API<br/>/x/web-interface/popular"]
        SPIDER["ACG Spider<br/>acg_spider.py"]
        MW["反爬中间件<br/>UA轮换 | 请求延迟 | AutoThrottle"]
        PIPELINE["MySQL Pipeline<br/>bv_id去重 | INSERT/UPDATE"]
    end

    subgraph 数据存储层["数据存储层 Data Storage"]
        DB[("SQLite / MySQL 数据库<br/>users | videos | comments<br/>user_favorites | video_stats_history")]
    end

    subgraph 业务逻辑层["业务逻辑层 Business Logic"]
        AUTH_SVC["认证服务<br/>JWT签发 | bcrypt校验"]
        VIDEO_SVC["视频服务<br/>CRUD | 搜索 | 排序"]
        DASH_SVC["分析服务<br/>聚合查询 | 统计计算"]
    end

    subgraph 展示层["展示层 Presentation"]
        HOME["首页<br/>视频列表 搜索 筛选"]
        DETAIL["视频详情<br/>评论 收藏"]
        DASHBOARD["数据看板<br/>7个分析图表"]
        BIGSCREEN["可视化大屏<br/>8个展示图表"]
        PROFILE["个人中心<br/>头像 密码 统计"]
    end

    API -->|"HTTP GET JSON"| SPIDER
    SPIDER -->|"Scrapy Request"| MW
    MW -->|"延迟请求"| API
    SPIDER -->|"yield Item"| PIPELINE
    PIPELINE -->|"SQLAlchemy Session"| DB

    DB -->|"ORM查询"| AUTH_SVC
    DB -->|"ORM查询"| VIDEO_SVC
    DB -->|"聚合查询"| DASH_SVC

    AUTH_SVC -->|"JWT Token"| HOME
    VIDEO_SVC -->|"JSON"| HOME
    VIDEO_SVC -->|"JSON"| DETAIL
    DASH_SVC -->|"JSON"| DASHBOARD
    DASH_SVC -->|"JSON"| BIGSCREEN
    AUTH_SVC -->|"JSON"| PROFILE
